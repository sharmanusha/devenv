{
  // Treat .tmpl files as plain text so the Docker/YAML linters
  // don't try to parse Go template placeholders ({{ .var }}) as
  // real Dockerfile/YAML syntax — they're only valid after rendering.
  "files.associations": {
    "*.tmpl": "plaintext"
  },

  // Disable Docker extension validation specifically for template files.
  "docker.enableDockerfileValidation": false
}
