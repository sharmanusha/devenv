# ── Stage 1: Builder ──────────────────────────────────────────────────────────
FROM python:{{ .python_version }}-slim AS builder
WORKDIR /app

# Install dependencies into a separate layer for caching
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt --target=/app/packages

# ── Stage 2: Production ───────────────────────────────────────────────────────
FROM python:{{ .python_version }}-slim
WORKDIR /app

# 🔒 Security: Copy only installed packages from builder, not pip itself
COPY --from=builder /app/packages /app/packages
ENV PYTHONPATH=/app/packages

# Copy application source
COPY . .

# 🔒 Security: Never run as root
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser

EXPOSE {{ .app_port }}

CMD {{ .run_command }}
