apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  namespace: {{ .app_name }}-ns
  name: {{ .app_name }}
spec:
  rules:
    - host: {{ .app_name }}.example.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ .app_name }}
                port:
                  number: 80
