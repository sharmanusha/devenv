# Build stage
FROM node:{{ .node_version }}-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html

# 🔒 Checkov standard: Never run as root!
# nginx also needs to write /var/run/nginx.pid — create it here so we can
# hand ownership to appuser before switching away from root.
RUN addgroup -S appgroup && adduser -S appuser -G appgroup && \
    touch /var/run/nginx.pid && \
    chown -R appuser:appgroup \
        /usr/share/nginx/html \
        /var/cache/nginx \
        /var/log/nginx \
        /etc/nginx/conf.d \
        /var/run/nginx.pid
USER appuser

EXPOSE {{ .app_port }}

# 🚀 Dynamic execution based on environment
CMD {{ .run_command }}
