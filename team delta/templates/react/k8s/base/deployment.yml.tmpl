apiVersion: apps/v1
kind: Deployment
metadata:
  namespace: {{ .app_name }}-ns
  name: {{ .app_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ .app_name }}
  template:
    metadata:
      labels:
        app: {{ .app_name }}
    spec:
      containers:
        - name: {{ .app_name }}
          image: {{ .app_name }}:latest
          imagePullPolicy: Always
          ports:
            - containerPort: {{ .app_port }}
