#!/usr/bin/env groovy

/**
 * Industrial-Grade Multi-Language Jenkins CI/CD Pipeline
 * Team Gamma Implementation
 * 
 * Supports: Node.js, Python, Java, Go
 * Features: Auto-detection, Linting, Testing, Security Scanning, OPA Policies, K8s Deployment
 */

@Library('pipeline-helpers') _

// Pipeline Configuration
def config = [
    timeout: 30,  // minutes
    retryAttempts: 3,
    registryHost: env.REGISTRY_HOST ?: 'localhost:5000',
    namespace: env.K8S_NAMESPACE ?: 'default',
    kubeconfig: env.KUBECONFIG ?: '~/.kube/config'
]

// Detected project metadata
def projectInfo = [:]

pipeline {
    agent {
        kubernetes {
            yaml libraryResource('pod-templates/multi-language-pod.yaml')
            defaultContainer 'jnlp'
        }
    }
    
    options {
        timeout(time: config.timeout, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '5'))
        disableConcurrentBuilds()
        skipDefaultCheckout()
    }
    
    environment {
        // Docker Configuration
        DOCKER_BUILDKIT = '1'
        DOCKER_TLS_VERIFY = '0'
        
        // Registry Configuration
        REGISTRY_HOST = "${config.registryHost}"
        REGISTRY_INSECURE = 'true'
        
        // Build Metadata
        BUILD_TIMESTAMP = sh(script: 'date +%Y%m%d-%H%M%S', returnStdout: true).trim()
        GIT_COMMIT_SHORT = ''
        IMAGE_TAG = ''
        
        // Kubernetes Configuration
        K8S_NAMESPACE = "${config.namespace}"
        
        // Artifact Paths
        ARTIFACT_DIR = 'artifacts'
        REPORT_DIR = 'reports'
        LOG_DIR = 'logs'
    }
    
    stages {
        stage('🚀 Initialize Pipeline') {
            steps {
                script {
                    printBanner()
                    echo "Pipeline: ${env.JOB_NAME}"
                    echo "Build: #${env.BUILD_NUMBER}"
                    echo "Node: ${env.NODE_NAME}"
                    echo "Workspace: ${env.WORKSPACE}"
                    
                    // Create artifact directories
                    sh """
                        mkdir -p ${ARTIFACT_DIR}/{build,test,lint,security,deployment}
                        mkdir -p ${REPORT_DIR}/{trivy,gitleaks,semgrep,opa}
                        mkdir -p ${LOG_DIR}
                    """
                }
            }
        }
        
        stage('📥 Clone Repository') {
            steps {
                script {
                    retry(config.retryAttempts) {
                        timeout(time: 5, unit: 'MINUTES') {
                            checkout scm
                            
                            // Set Git metadata
                            env.GIT_COMMIT_SHORT = sh(
                                script: 'git rev-parse --short HEAD',
                                returnStdout: true
                            ).trim()
                            
                            env.IMAGE_TAG = "${env.BUILD_NUMBER}-${env.GIT_COMMIT_SHORT}"
                            
                            echo "✓ Cloned commit: ${env.GIT_COMMIT_SHORT}"
                            
                            // Save commit info
                            sh """
                                echo "Commit: ${env.GIT_COMMIT}" > ${ARTIFACT_DIR}/git-info.txt
                                echo "Short: ${env.GIT_COMMIT_SHORT}" >> ${ARTIFACT_DIR}/git-info.txt
                                echo "Branch: ${env.GIT_BRANCH ?: 'N/A'}" >> ${ARTIFACT_DIR}/git-info.txt
                                echo "Author: \$(git log -1 --pretty=format:'%an <%ae>')" >> ${ARTIFACT_DIR}/git-info.txt
                                echo "Message: \$(git log -1 --pretty=format:'%s')" >> ${ARTIFACT_DIR}/git-info.txt
                            """
                        }
                    }
                }
            }
        }
        
        stage('🔍 Detect Project Type') {
            steps {
                script {
                    echo "Detecting project type..."
                    
                    // Detect project language and framework
                    projectInfo = detectProject()
                    
                    echo """
╔════════════════════════════════════════╗
║        PROJECT DETECTION RESULTS       ║
╠════════════════════════════════════════╣
║ Language:   ${projectInfo.language.padRight(27)}║
║ Framework:  ${projectInfo.framework.padRight(27)}║
║ Build Tool: ${projectInfo.buildTool.padRight(27)}║
║ App Name:   ${projectInfo.appName.padRight(27)}║
╚════════════════════════════════════════╝
"""
                    
                    // Save project info
                    writeJSON file: "${ARTIFACT_DIR}/project-info.json", json: projectInfo
                    
                    // Validate project structure
                    validateProjectStructure(projectInfo)
                }
            }
        }
        
        stage('✅ Code Validation') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        echo "Running code validation checks..."
                        
                        parallel(
                            "File Existence": {
                                validateFiles(projectInfo)
                            },
                            "Syntax Check": {
                                validateSyntax(projectInfo)
                            },
                            "Encoding Check": {
                                sh """
                                    echo "Checking file encodings..."
                                    find . -type f -name "*.${projectInfo.fileExtension}" -exec file {} \\; | tee ${LOG_DIR}/encoding-check.log
                                """
                            }
                        )
                        
                        echo "✓ Code validation passed"
                    }
                }
            }
        }
        
        stage('📋 Linting') {
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {
                        echo "Running linters for ${projectInfo.language}..."
                        
                        try {
                            runLinting(projectInfo)
                            echo "✓ Linting passed"
                        } catch (Exception e) {
                            echo "⚠ Linting found issues but continuing..."
                            currentBuild.result = 'UNSTABLE'
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORT_DIR}/lint-*.{xml,json,txt}", allowEmptyArchive: true
                    publishLintResults(projectInfo)
                }
            }
        }
        
        stage('🧪 Unit Testing') {
            steps {
                script {
                    timeout(time: 15, unit: 'MINUTES') {
                        echo "Running unit tests for ${projectInfo.language}..."
                        
                        try {
                            runTests(projectInfo)
                            echo "✓ All tests passed"
                        } catch (Exception e) {
                            error "❌ Tests failed: ${e.message}"
                        }
                    }
                }
            }
            post {
                always {
                    publishTestResults(projectInfo)
                    archiveArtifacts artifacts: "${REPORT_DIR}/test-*.{xml,json,html}", allowEmptyArchive: true
                    
                    // Code coverage report
                    script {
                        if (fileExists("${REPORT_DIR}/coverage")) {
                            publishHTML([
                                reportDir: "${REPORT_DIR}/coverage",
                                reportFiles: 'index.html',
                                reportName: 'Code Coverage Report',
                                keepAll: true
                            ])
                        }
                    }
                }
            }
        }
        
        stage('🔒 Security Scanning') {
            parallel {
                stage('Trivy - Filesystem Scan') {
                    steps {
                        container('trivy') {
                            script {
                                timeout(time: 10, unit: 'MINUTES') {
                                    echo "Running Trivy filesystem scan..."
                                    
                                    retry(2) {
                                        sh """
                                            trivy fs \
                                                --severity HIGH,CRITICAL \
                                                --format json \
                                                --output ${REPORT_DIR}/trivy/trivy-fs-scan.json \
                                                --timeout 10m \
                                                .
                                            
                                            trivy fs \
                                                --severity HIGH,CRITICAL \
                                                --format table \
                                                --output ${REPORT_DIR}/trivy/trivy-fs-scan.txt \
                                                .
                                        """
                                    }
                                    
                                    // Check for critical vulnerabilities
                                    def triviaReport = readJSON file: "${REPORT_DIR}/trivy/trivy-fs-scan.json"
                                    def criticalCount = countCriticalVulnerabilities(triviaReport)
                                    
                                    if (criticalCount > 0) {
                                        echo "⚠ Found ${criticalCount} critical vulnerabilities"
                                        currentBuild.result = 'UNSTABLE'
                                    } else {
                                        echo "✓ No critical vulnerabilities found"
                                    }
                                }
                            }
                        }
                    }
                }
                
                stage('Gitleaks - Secret Scan') {
                    steps {
                        container('gitleaks') {
                            script {
                                timeout(time: 5, unit: 'MINUTES') {
                                    echo "Running Gitleaks secret scan..."
                                    
                                    def exitCode = sh(
                                        script: """
                                            gitleaks detect \
                                                --source . \
                                                --report-path ${REPORT_DIR}/gitleaks/gitleaks-report.json \
                                                --report-format json \
                                                --verbose \
                                                --no-git || true
                                        """,
                                        returnStatus: true
                                    )
                                    
                                    if (exitCode != 0) {
                                        error "❌ Secrets detected! Review ${REPORT_DIR}/gitleaks/gitleaks-report.json"
                                    } else {
                                        echo "✓ No secrets detected"
                                    }
                                }
                            }
                        }
                    }
                }
                
                stage('Semgrep - SAST Scan') {
                    steps {
                        container('semgrep') {
                            script {
                                timeout(time: 10, unit: 'MINUTES') {
                                    echo "Running Semgrep SAST scan..."
                                    
                                    sh """
                                        semgrep \
                                            --config auto \
                                            --json \
                                            --output ${REPORT_DIR}/semgrep/semgrep-results.json \
                                            . || true
                                        
                                        semgrep \
                                            --config auto \
                                            --output ${REPORT_DIR}/semgrep/semgrep-results.txt \
                                            . || true
                                    """
                                    
                                    def semgrepReport = readJSON file: "${REPORT_DIR}/semgrep/semgrep-results.json"
                                    def errorCount = semgrepReport.errors?.size() ?: 0
                                    
                                    if (errorCount > 0) {
                                        echo "⚠ Found ${errorCount} security issues"
                                        currentBuild.result = 'UNSTABLE'
                                    } else {
                                        echo "✓ No security issues found"
                                    }
                                }
                            }
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORT_DIR}/**/*-scan.{json,txt}", allowEmptyArchive: true
                }
            }
        }
        
        stage('🐳 Docker Build') {
            steps {
                container('docker') {
                    script {
                        timeout(time: 20, unit: 'MINUTES') {
                            echo "Building Docker image..."
                            
                            def imageName = "${env.REGISTRY_HOST}/${projectInfo.appName}"
                            def imageFullTag = "${imageName}:${env.IMAGE_TAG}"
                            def imageLatestTag = "${imageName}:latest"
                            
                            retry(config.retryAttempts) {
                                sh """
                                    docker build \
                                        --build-arg BUILD_NUMBER=${env.BUILD_NUMBER} \
                                        --build-arg GIT_COMMIT=${env.GIT_COMMIT_SHORT} \
                                        --build-arg BUILD_DATE=${env.BUILD_TIMESTAMP} \
                                        --tag ${imageFullTag} \
                                        --tag ${imageLatestTag} \
                                        --label "build.number=${env.BUILD_NUMBER}" \
                                        --label "git.commit=${env.GIT_COMMIT_SHORT}" \
                                        --label "build.timestamp=${env.BUILD_TIMESTAMP}" \
                                        --progress=plain \
                                        . 2>&1 | tee ${LOG_DIR}/docker-build.log
                                """
                            }
                            
                            echo "✓ Docker image built successfully"
                            echo "  Image: ${imageFullTag}"
                            
                            // Save image metadata
                            sh """
                                docker inspect ${imageFullTag} > ${ARTIFACT_DIR}/docker-inspect.json
                                docker history ${imageFullTag} > ${ARTIFACT_DIR}/docker-history.txt
                            """
                            
                            env.DOCKER_IMAGE = imageFullTag
                        }
                    }
                }
            }
        }
        
        stage('🔍 Docker Image Scan') {
            steps {
                container('trivy') {
                    script {
                        timeout(time: 15, unit: 'MINUTES') {
                            echo "Scanning Docker image with Trivy..."
                            
                            retry(2) {
                                sh """
                                    trivy image \
                                        --severity HIGH,CRITICAL \
                                        --format json \
                                        --output ${REPORT_DIR}/trivy/trivy-image-scan.json \
                                        --timeout 15m \
                                        --insecure \
                                        ${env.DOCKER_IMAGE}
                                    
                                    trivy image \
                                        --severity HIGH,CRITICAL \
                                        --format table \
                                        --output ${REPORT_DIR}/trivy/trivy-image-scan.txt \
                                        --insecure \
                                        ${env.DOCKER_IMAGE}
                                """
                            }
                            
                            // Parse scan results
                            def scanReport = readJSON file: "${REPORT_DIR}/trivy/trivy-image-scan.json"
                            def criticalCount = countCriticalVulnerabilities(scanReport)
                            
                            if (criticalCount > 5) {
                                error "❌ Image has ${criticalCount} critical vulnerabilities (threshold: 5)"
                            } else if (criticalCount > 0) {
                                echo "⚠ Image has ${criticalCount} critical vulnerabilities"
                                currentBuild.result = 'UNSTABLE'
                            } else {
                                echo "✓ Image scan passed"
                            }
                        }
                    }
                }
            }
        }
        
        stage('📜 OPA Policy Validation') {
            steps {
                container('conftest') {
                    script {
                        timeout(time: 5, unit: 'MINUTES') {
                            echo "Validating Kubernetes manifests with OPA/Conftest..."
                            
                            // Run Conftest against K8s manifests
                            def exitCode = sh(
                                script: """
                                    conftest test \
                                        --policy pipelines/opa-policies \
                                        --output json \
                                        --all-namespaces \
                                        k8s/base/*.yml > ${REPORT_DIR}/opa/conftest-results.json || true
                                    
                                    conftest test \
                                        --policy pipelines/opa-policies \
                                        --output table \
                                        k8s/base/*.yml > ${REPORT_DIR}/opa/conftest-results.txt || true
                                """,
                                returnStatus: true
                            )
                            
                            // Parse results
                            def opaReport = readJSON file: "${REPORT_DIR}/opa/conftest-results.json"
                            def failures = countOPAFailures(opaReport)
                            
                            if (failures > 0) {
                                error "❌ OPA policy validation failed with ${failures} violations"
                            } else {
                                echo "✓ All OPA policies passed"
                            }
                        }
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${REPORT_DIR}/opa/*", allowEmptyArchive: true
                }
            }
        }
        
        stage('📤 Registry Push') {
            steps {
                container('docker') {
                    script {
                        timeout(time: 10, unit: 'MINUTES') {
                            echo "Pushing image to registry..."
                            
                            retry(config.retryAttempts) {
                                sh """
                                    docker push ${env.DOCKER_IMAGE} 2>&1 | tee ${LOG_DIR}/docker-push.log
                                    docker push ${env.REGISTRY_HOST}/${projectInfo.appName}:latest
                                """
                            }
                            
                            echo "✓ Image pushed successfully"
                            echo "  Registry: ${env.REGISTRY_HOST}"
                            echo "  Image: ${projectInfo.appName}:${env.IMAGE_TAG}"
                        }
                    }
                }
            }
        }
        
        stage('☸️ Kubernetes Deployment') {
            steps {
                container('kubectl') {
                    script {
                        timeout(time: 10, unit: 'MINUTES') {
                            echo "Deploying to Kubernetes..."
                            
                            // Update image in deployment
                            sh """
                                # Create namespace if not exists
                                kubectl create namespace ${env.K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                                
                                # Apply Kubernetes manifests
                                kubectl apply -k k8s/overlays/local -n ${env.K8S_NAMESPACE} 2>&1 | tee ${LOG_DIR}/kubectl-apply.log
                                
                                # Update deployment image
                                kubectl set image deployment/${projectInfo.appName} \
                                    ${projectInfo.appName}=${env.DOCKER_IMAGE} \
                                    -n ${env.K8S_NAMESPACE} \
                                    --record
                                
                                # Annotate deployment with build info
                                kubectl annotate deployment/${projectInfo.appName} \
                                    build.number="${env.BUILD_NUMBER}" \
                                    git.commit="${env.GIT_COMMIT_SHORT}" \
                                    build.timestamp="${env.BUILD_TIMESTAMP}" \
                                    kubernetes.io/change-cause="Jenkins Build #${env.BUILD_NUMBER}" \
                                    -n ${env.K8S_NAMESPACE} \
                                    --overwrite
                            """
                            
                            echo "✓ Deployment manifests applied"
                        }
                    }
                }
            }
        }
        
        stage('✅ Deployment Verification') {
            steps {
                container('kubectl') {
                    script {
                        timeout(time: 10, unit: 'MINUTES') {
                            echo "Verifying deployment..."
                            
                            // Wait for rollout
                            sh """
                                echo "Waiting for rollout to complete..."
                                kubectl rollout status deployment/${projectInfo.appName} \
                                    -n ${env.K8S_NAMESPACE} \
                                    --timeout=8m 2>&1 | tee ${LOG_DIR}/rollout-status.log
                            """
                            
                            // Verify pod health
                            verifyPodHealth(projectInfo.appName, env.K8S_NAMESPACE)
                            
                            // Verify service accessibility
                            verifyServiceAccessibility(projectInfo.appName, env.K8S_NAMESPACE)
                            
                            // Run smoke tests
                            runSmokeTests(projectInfo)
                            
                            echo "✓ Deployment verification completed successfully"
                        }
                    }
                }
            }
        }
        
        stage('📊 Generate Reports') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        echo "Generating build summary..."
                        
                        generateBuildSummary(projectInfo)
                        generateDeploymentReport(projectInfo)
                        
                        echo "✓ Reports generated"
                    }
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "Pipeline execution completed"
                
                // Archive all artifacts
                archiveArtifacts artifacts: "${ARTIFACT_DIR}/**/*", allowEmptyArchive: true
                archiveArtifacts artifacts: "${LOG_DIR}/**/*", allowEmptyArchive: true
                
                // Cleanup workspace
                cleanWs(
                    deleteDirs: true,
                    patterns: [
                        [pattern: 'node_modules', type: 'INCLUDE'],
                        [pattern: '.pytest_cache', type: 'INCLUDE'],
                        [pattern: 'target', type: 'INCLUDE']
                    ]
                )
            }
        }
        
        success {
            script {
                def duration = currentBuild.durationString.replace(' and counting', '')
                echo """
╔═══════════════════════════════════════════════╗
║          🎉 PIPELINE SUCCESSFUL 🎉            ║
╠═══════════════════════════════════════════════╣
║ Build:      #${env.BUILD_NUMBER}                              ║
║ Duration:   ${duration}                    ║
║ Image:      ${projectInfo.appName}:${env.IMAGE_TAG} ║
║ Namespace:  ${env.K8S_NAMESPACE}                         ║
╚═══════════════════════════════════════════════╝
"""
                
                // Send success notification
                // notifySuccess(projectInfo)
            }
        }
        
        failure {
            script {
                echo """
╔═══════════════════════════════════════════════╗
║           ❌ PIPELINE FAILED ❌               ║
╠═══════════════════════════════════════════════╣
║ Build:      #${env.BUILD_NUMBER}                              ║
║ Stage:      ${env.STAGE_NAME}                         ║
║ Check logs for details                        ║
╚═══════════════════════════════════════════════╝
"""
                
                // Send failure notification
                // notifyFailure(projectInfo)
            }
        }
        
        unstable {
            script {
                echo "⚠ Pipeline completed with warnings"
                // notifyUnstable(projectInfo)
            }
        }
    }
}

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

def printBanner() {
    echo """
╔════════════════════════════════════════════════════════════════╗
║                                                                ║
║          TEAM GAMMA - INDUSTRIAL CI/CD PIPELINE                ║
║                                                                ║
║  Multi-Language  │  Security  │  OPA  │  K8s  │  Automation   ║
║                                                                ║
╚════════════════════════════════════════════════════════════════╝
"""
}

def detectProject() {
    def info = [:]
    
    // Detect Node.js
    if (fileExists('package.json')) {
        def packageJson = readJSON file: 'package.json'
        info.language = 'Node.js'
        info.appName = packageJson.name ?: 'nodejs-app'
        info.fileExtension = 'js'
        info.buildTool = 'npm'
        
        if (packageJson.dependencies?.react) {
            info.framework = 'React'
        } else if (packageJson.dependencies?.express) {
            info.framework = 'Express'
        } else if (packageJson.dependencies?.next) {
            info.framework = 'Next.js'
        } else {
            info.framework = 'Node.js'
        }
        
        return info
    }
    
    // Detect Python
    if (fileExists('requirements.txt')) {
        info.language = 'Python'
        info.fileExtension = 'py'
        info.buildTool = 'pip'
        
        def requirements = readFile('requirements.txt')
        if (requirements.contains('django')) {
            info.framework = 'Django'
            info.appName = 'django-app'
        } else if (requirements.contains('fastapi')) {
            info.framework = 'FastAPI'
            info.appName = 'fastapi-app'
        } else if (requirements.contains('flask')) {
            info.framework = 'Flask'
            info.appName = 'flask-app'
        } else {
            info.framework = 'Python'
            info.appName = 'python-app'
        }
        
        return info
    }
    
    // Detect Java
    if (fileExists('pom.xml')) {
        def pom = readFile('pom.xml')
        info.language = 'Java'
        info.framework = 'Spring Boot'
        info.fileExtension = 'java'
        info.buildTool = 'Maven'
        
        // Extract artifact ID from pom.xml
        def matcher = pom =~ /<artifactId>(.*?)<\/artifactId>/
        info.appName = matcher ? matcher[0][1] : 'java-app'
        
        return info
    }
    
    if (fileExists('build.gradle')) {
        info.language = 'Java'
        info.framework = 'Spring Boot'
        info.fileExtension = 'java'
        info.buildTool = 'Gradle'
        info.appName = 'java-app'
        
        return info
    }
    
    // Detect Go
    if (fileExists('go.mod')) {
        def goMod = readFile('go.mod')
        info.language = 'Go'
        info.framework = 'Go'
        info.fileExtension = 'go'
        info.buildTool = 'go'
        
        // Extract module name
        def matcher = goMod =~ /module (.*)/
        def moduleName = matcher ? matcher[0][1] : 'go-app'
        info.appName = moduleName.tokenize('/')[-1]
        
        return info
    }
    
    // Default/Unknown
    error "❌ Could not detect project type. Supported: Node.js, Python, Java, Go"
}

def validateProjectStructure(projectInfo) {
    echo "Validating project structure..."
    
    def required Files = []
    
    switch(projectInfo.language) {
        case 'Node.js':
            requiredFiles = ['package.json', 'Dockerfile']
            break
        case 'Python':
            requiredFiles = ['requirements.txt', 'Dockerfile']
            break
        case 'Java':
            requiredFiles = ['Dockerfile']
            if (projectInfo.buildTool == 'Maven') {
                requiredFiles << 'pom.xml'
            } else {
                requiredFiles << 'build.gradle'
            }
            break
        case 'Go':
            requiredFiles = ['go.mod', 'Dockerfile']
            break
    }
    
    requiredFiles << 'k8s/base/deployment.yml'
    requiredFiles << 'k8s/base/service.yml'
    
    requiredFiles.each { file ->
        if (!fileExists(file)) {
            echo "⚠ Missing recommended file: ${file}"
        }
    }
}

def validateFiles(projectInfo) {
    echo "Validating project files..."
    
    sh """
        echo "Checking for required files..."
        ls -la | tee ${LOG_DIR}/file-list.txt
    """
}

def validateSyntax(projectInfo) {
    echo "Validating syntax..."
    
    switch(projectInfo.language) {
        case 'Node.js':
            container('node') {
                sh 'find . -name "*.js" -not -path "*/node_modules/*" -exec node --check {} \\; || true'
            }
            break
        case 'Python':
            container('python') {
                sh 'find . -name "*.py" -exec python -m py_compile {} \\; || true'
            }
            break
    }
}

def runLinting(projectInfo) {
    switch(projectInfo.language) {
        case 'Node.js':
            container('node') {
                sh """
                    npm install --no-save eslint || true
                    npx eslint . --format json --output-file ${REPORT_DIR}/lint-eslint.json || true
                    npx eslint . --format stylish > ${REPORT_DIR}/lint-eslint.txt || true
                """
            }
            break
            
        case 'Python':
            container('python') {
                sh """
                    pip install --quiet pylint || true
                    pylint **/*.py --output-format=json > ${REPORT_DIR}/lint-pylint.json || true
                    pylint **/*.py > ${REPORT_DIR}/lint-pylint.txt || true
                """
            }
            break
            
        case 'Java':
            container('maven') {
                sh """
                    mvn checkstyle:checkstyle || true
                    cp target/checkstyle-result.xml ${REPORT_DIR}/lint-checkstyle.xml || true
                """
            }
            break
            
        case 'Go':
            container('go') {
                sh """
                    gofmt -l . > ${REPORT_DIR}/lint-gofmt.txt || true
                    go vet ./... 2>&1 | tee ${REPORT_DIR}/lint-govet.txt || true
                """
            }
            break
    }
}

def publishLintResults(projectInfo) {
    // Publish lint results based on available plugins
    echo "Publishing lint results..."
}

def runTests(projectInfo) {
    switch(projectInfo.language) {
        case 'Node.js':
            container('node') {
                sh """
                    npm install
                    npm test -- --ci --coverage --watchAll=false --reporters=default --reporters=jest-junit || true
                    cp junit.xml ${REPORT_DIR}/test-results.xml || true
                """
            }
            break
            
        case 'Python':
            container('python') {
                sh """
                    pip install -r requirements.txt
                    pip install pytest pytest-cov pytest-html
                    pytest --junitxml=${REPORT_DIR}/test-results.xml \
                           --html=${REPORT_DIR}/test-report.html \
                           --cov=. \
                           --cov-report=html:${REPORT_DIR}/coverage \
                           --cov-report=xml:${REPORT_DIR}/coverage.xml || true
                """
            }
            break
            
        case 'Java':
            container('maven') {
                sh """
                    mvn test -Dmaven.test.failure.ignore=true
                    cp target/surefire-reports/*.xml ${REPORT_DIR}/ || true
                """
            }
            break
            
        case 'Go':
            container('go') {
                sh """
                    go test -v ./... -coverprofile=${REPORT_DIR}/coverage.out 2>&1 | tee ${REPORT_DIR}/test-results.txt
                    go tool cover -html=${REPORT_DIR}/coverage.out -o ${REPORT_DIR}/coverage.html || true
                """
            }
            break
    }
}

def publishTestResults(projectInfo) {
    // Publish JUnit test results
    if (fileExists("${REPORT_DIR}/test-results.xml")) {
        junit "${REPORT_DIR}/test-results.xml"
    }
}

def countCriticalVulnerabilities(report) {
    def count = 0
    
    if (report.Results) {
        report.Results.each { result ->
            result.Vulnerabilities?.each { vuln ->
                if (vuln.Severity == 'CRITICAL') {
                    count++
                }
            }
        }
    }
    
    return count
}

def countOPAFailures(report) {
    def failures = 0
    
    if (report instanceof List) {
        report.each { result ->
            failures += result.failures?.size() ?: 0
        }
    }
    
    return failures
}

def verifyPodHealth(appName, namespace) {
    echo "Verifying pod health..."
    
    def maxRetries = 12
    def retryInterval = 10  // seconds
    
    for (int i = 0; i < maxRetries; i++) {
        def podStatus = sh(
            script: """
                kubectl get pods -n ${namespace} -l app=${appName} \
                    -o jsonpath='{.items[0].status.phase}' 2>/dev/null || echo 'NotFound'
            """,
            returnStdout: true
        ).trim()
        
        if (podStatus == 'Running') {
            // Check if containers are ready
            def readyContainers = sh(
                script: """
                    kubectl get pods -n ${namespace} -l app=${appName} \
                        -o jsonpath='{.items[0].status.containerStatuses[0].ready}'
                """,
                returnStdout: true
            ).trim()
            
            if (readyContainers == 'true') {
                echo "✓ Pod is healthy and running"
                return
            }
        }
        
        echo "Waiting for pod to be ready... (${i + 1}/${maxRetries})"
        sleep retryInterval
    }
    
    error "❌ Pod failed to become healthy within timeout"
}

def verifyServiceAccessibility(appName, namespace) {
    echo "Verifying service accessibility..."
    
    def serviceExists = sh(
        script: "kubectl get service ${appName} -n ${namespace} --no-headers 2>/dev/null | wc -l",
        returnStdout: true
    ).trim()
    
    if (serviceExists == '0') {
        error "❌ Service ${appName} not found in namespace ${namespace}"
    }
    
    // Get service endpoints
    sh """
        kubectl get endpoints ${appName} -n ${namespace} -o yaml | tee ${LOG_DIR}/service-endpoints.yaml
    """
    
    echo "✓ Service is accessible"
}

def runSmokeTests(projectInfo) {
    echo "Running smoke tests..."
    
    // Get service ClusterIP
    def clusterIP = sh(
        script: "kubectl get service ${projectInfo.appName} -n ${env.K8S_NAMESPACE} -o jsonpath='{.spec.clusterIP}'",
        returnStdout: true
    ).trim()
    
    def port = sh(
        script: "kubectl get service ${projectInfo.appName} -n ${env.K8S_NAMESPACE} -o jsonpath='{.spec.ports[0].port}'",
        returnStdout: true
    ).trim()
    
    // Run basic HTTP check
    def exitCode = sh(
        script: """
            kubectl run smoke-test-${env.BUILD_NUMBER} \
                --image=curlimages/curl:latest \
                --restart=Never \
                --rm \
                -i \
                -n ${env.K8S_NAMESPACE} \
                -- curl -f -s -o /dev/null -w '%{http_code}' http://${clusterIP}:${port}/ || true
        """,
        returnStatus: true
    )
    
    if (exitCode == 0) {
        echo "✓ Smoke tests passed"
    } else {
        echo "⚠ Smoke tests failed (non-blocking)"
        currentBuild.result = 'UNSTABLE'
    }
}

def generateBuildSummary(projectInfo) {
    def summary = """
╔════════════════════════════════════════════════════════════════╗
║                      BUILD SUMMARY                             ║
╠════════════════════════════════════════════════════════════════╣
║ Project:     ${projectInfo.appName}                                    ║
║ Language:    ${projectInfo.language}                                   ║
║ Framework:   ${projectInfo.framework}                                  ║
║ Build:       #${env.BUILD_NUMBER}                                      ║
║ Commit:      ${env.GIT_COMMIT_SHORT}                                   ║
║ Image:       ${projectInfo.appName}:${env.IMAGE_TAG}                   ║
║ Registry:    ${env.REGISTRY_HOST}                                      ║
║ Namespace:   ${env.K8S_NAMESPACE}                                      ║
║ Status:      ${currentBuild.currentResult}                             ║
╚════════════════════════════════════════════════════════════════╝
"""
    
    echo summary
    writeFile file: "${ARTIFACT_DIR}/build-summary.txt", text: summary
}

